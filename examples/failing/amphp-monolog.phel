;; There's trouble starting Monolog via nREPL client.
;; nREPL server itself already uses Monolog so it might be a case that it does
;; not support "nested" instances or something.

;; Tested both with stdout (A) and file logging (B)

;; Adapted from https://github.com/jasalt/phel-amphp-examples/blob/main/src/http-server/event-source.phel


(ns phel-nrepl\examples\failing\amphp-monolog)


;;;;; (A)

(def log-handler (php/new \Amp\Log\StreamHandler (php/amp\bytestream\getstdout)))
(def log-processor (php/new \Monolog\Processor\PsrLogMessageProcessor))
(php/-> log-handler (pushProcessor log-processor))
;; nREPL server crashes with:
;; Unhandled future: Error: "Object of class Amp\Log\StreamHandler could not be converted to string"; Await the Future with Future::await() before the future is destroyed or use Future::ignore() to suppress this exception. Enable assertions and set AMP_DEBUG=true in the process environment to track its origin. // file: /home/user/dev/phel/phel-nrepl/vendor/amphp/amp/src/Internal/FutureState.php


;;;;; (B)
;; File logging example: https://amphp.org/log#usage

(def tempfile (php/tempnam "/tmp" "phel-monolog"))
(php/touch tempfile)  ; ensuring log file exists
(def log-handler (php/new \Amp\Log\StreamHandler (php/amp\file\openfile tempfile "w")))
(def logger (php/new \Monolog\Logger "foo"))
(php/-> logger (pushHandler log-handler))
;; Unhandled future: Error: "Object of class Monolog\Logger could not be converted to string"; Await the Future with Future::await() before the future is destroyed or use Future::ignore() to suppress this exception. Enable assertions and set AMP_DEBUG=true in the process environment to track its origin. // file: /home/user/dev/phel/phel-nrepl/vendor/amphp/amp/src/Internal/FutureState.php


;; Running with assertions does not provide any extra info:
;; AMPHP_DEBUG=true php8.4 -d zend.assertions=1 vendor/bin/phel run src/nrepl.phel


